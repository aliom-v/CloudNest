NEXT_PUBLIC_SITE_NAME=CloudNest
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Optional if you enable server-side signed uploads instead of unsigned presets.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_FOLDER=cloudnest/uploads
NEXT_PUBLIC_DEFAULT_UPLOAD_TAGS=imagebed,mvp,web-upload

# Required for server-side signed upload and admin APIs.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AUTH_ALLOWED_EMAILS=
ADMIN_LOGIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_HOURS=24
# Set to true only when you want signed upload params to be publicly available to site visitors.
ALLOW_PUBLIC_SIGNED_UPLOAD=false
# Set to false after signed upload is fully verified and you want to disable unsigned fallback.
ALLOW_UNSIGNED_UPLOAD_FALLBACK=true
# Optional but recommended for persistent audit storage on Vercel.
BLOB_READ_WRITE_TOKEN=
