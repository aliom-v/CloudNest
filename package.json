{
  "name": "cloudnest-imagebed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,css,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import ./tests/helpers/register-mocks.mjs --test tests/*.test.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@vercel/blob": "2.3.1",
    "next": "16.2.1",
    "p-limit": "7.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3"
  }
}
